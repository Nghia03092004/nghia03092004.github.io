---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../site.config';
---

<BaseLayout title="About" description={`About ${siteConfig.title}`}>
	<section class="page-intro">
		<span class="eyebrow">About</span>
		<h1>A home for durable notes.</h1>
		<p>
			This site is structured like a small archive instead of a generic portfolio. The goal is
			to make essays, technical write-ups, and Project Euler notes easy to browse years later.
		</p>
	</section>

	<section class="section-panel">
		<div class="track-grid">
			<div class="card" data-tone="warm">
				<h3>Why essays live here</h3>
				<p>
					Long-form writing is where rough intuition turns into reusable thinking. The essays
					section is for topics that deserve more than a social post.
				</p>
			</div>
			<div class="card" data-tone="cool">
				<h3>Why code notes are separate</h3>
				<p>
					Implementation details age differently from essays. Keeping code notes separate makes
					snippets, architecture logs, and project write-ups much easier to scan.
				</p>
			</div>
			<div class="card" data-tone="olive">
				<h3>Why Euler gets its own archive</h3>
				<p>
					Problem solving works best when the log is searchable. Each entry can track status,
					language, and solution notes without turning the main blog into a dump.
				</p>
			</div>
		</div>
	</section>
</BaseLayout>
