---
import CompetitiveProgrammingPagination from '../../../../features/competitive-programming/components/CompetitiveProgrammingPagination.astro';
import CompetitiveProgrammingEditorial from '../../../../features/competitive-programming/components/CompetitiveProgrammingEditorial.astro';
import CompetitiveProgrammingSourceTabs from '../../../../features/competitive-programming/components/CompetitiveProgrammingSourceTabs.astro';
import PostLayout from '../../../../layouts/PostLayout.astro';
import { withBase } from '../../../../lib/paths';
import {
	getCompetitiveProgrammingRecord,
	getCompetitiveProgrammingRecords,
	getCompetitiveProgrammingSources,
	type CompetitiveProgrammingTrack,
} from '../../../../features/competitive-programming/lib/competitive-programming';
import {
	extractLatexDocument,
	renderLatexContent,
} from '../../../../features/competitive-programming/lib/latex-editorial';

export async function getStaticPaths() {
	const records = await getCompetitiveProgrammingRecords();

	return records.map((record) => ({
		params: {
			track: record.track,
			year: String(record.year),
			slug: record.slug,
		},
	}));
}

const trackParam = Astro.params.track;
if (trackParam !== 'icpc' && trackParam !== 'ioi') {
	throw new Error(`Unsupported competitive programming track: ${trackParam}`);
}

const year = Number(Astro.params.year);
if (!Number.isInteger(year)) {
	throw new Error(`Invalid competitive programming year: ${Astro.params.year}`);
}

const slug = Astro.params.slug;
if (!slug) {
	throw new Error('Missing competitive programming slug.');
}

const track = trackParam as CompetitiveProgrammingTrack;
const record = await getCompetitiveProgrammingRecord(track, year, slug);
if (!record) {
	throw new Error(`Competitive programming entry not found for ${track}/${year}/${slug}.`);
}

const [records, sources] = await Promise.all([
	getCompetitiveProgrammingRecords(track),
	getCompetitiveProgrammingSources(record),
]);

const latexDocument = extractLatexDocument(sources.tex);
const statementFromTex =
	!record.hasStatementText && latexDocument.statementSource
		? renderLatexContent(latexDocument.statementSource, {
				headingDepthOffset: 2,
				headingSlugPrefix: `cp-statement-${record.id}`,
			})
		: undefined;
const editorial = renderLatexContent(latexDocument.editorialSource || latexDocument.body, {
	headingDepthOffset: 2,
	headingSlugPrefix: `cp-editorial-${record.id}`,
});
const statementDescription =
	record.hasStatementText && sources.statementText
		? 'Copied statement text kept beside the solution archive for direct reference.'
		: statementFromTex
			? `Rendered from the "${latexDocument.statementTitle ?? 'Problem Statement'}" section inside solution.tex because this entry has no separate statement file.`
			: 'This archive entry does not include a standalone statement file or a dedicated statement section in solution.tex.';

const currentIndex = records.findIndex((entry) => entry.id === record.id);
const previousRecord = currentIndex > 0 ? records[currentIndex - 1] : undefined;
const nextRecord =
	currentIndex >= 0 && currentIndex < records.length - 1 ? records[currentIndex + 1] : undefined;

const headings = [
	{ depth: 2, slug: 'problem-statement', text: 'Problem Statement' },
	{ depth: 2, slug: 'editorial', text: 'Editorial' },
	...editorial.headings,
	{ depth: 2, slug: 'code', text: 'Code' },
	{ depth: 2, slug: 'source-files', text: 'Source Files' },
];

const metaItems = [
	{ label: 'Track', value: record.trackLabel },
	{ label: 'Year', value: String(record.year) },
	{ label: 'Files', value: record.hasStatementText ? 'TeX, C++, statement assets' : 'TeX and C++' },
	{ label: 'Folder', value: record.sourceDirectory },
];

const tags = [
	record.trackLabel,
	String(record.year),
	'TeX',
	'C++',
	...(record.hasStatementText ? ['statement text'] : []),
	...(record.hasStatementPdf ? ['statement pdf'] : []),
];

const primaryLink = record.hasStatementPdf
	? { label: 'Open statement PDF', href: withBase(record.assetUrls.statementPdf!) }
	: { label: 'Open raw TeX', href: withBase(record.assetUrls.tex) };

const secondaryLinks = [
	{ label: 'Open raw C++', href: withBase(record.assetUrls.cpp) },
	...(record.assetUrls.statementText
		? [{ label: 'Open raw statement', href: withBase(record.assetUrls.statementText) }]
		: []),
	...(record.assetUrls.yearPacket
		? [{ label: 'Year problem packet', href: withBase(record.assetUrls.yearPacket) }]
		: []),
];
---

<PostLayout
	title={`${record.trackLabel} ${record.year} - ${record.displayTitle}`}
	description={record.description}
	published={record.updated}
	publishedLabel="Source sync"
	eyebrow="Competitive Programming"
	backHref={`/competitive-programming/${record.track}`}
	backLabel={`All ${record.trackLabel} entries`}
	tags={tags}
	metaItems={metaItems}
	headings={headings}
	primaryLink={primaryLink}
	secondaryLinks={secondaryLinks}
>
	<section class="cp-detail-note" id="archive-overview">
		<div class="cp-detail-note__header">
			<span class="section-label">Source of truth</span>
			<h2>Source-first archive entry</h2>
		</div>
		<p>
			This page is built from the copied files in <code>{record.sourceDirectory}</code>. Edit
			<code> {record.sourcePaths.tex}</code> to update the written solution and
			<code> {record.sourcePaths.cpp}</code> to update the implementation.
		</p>
		<p>
			The website does not replace those files with hand-maintained HTML. It reads the copied source
			tree during the build and exposes the exact files below.
		</p>
		<div class="chip-row">
			<a class="button button--ghost" href={withBase(record.assetUrls.tex)}>Raw TeX</a>
			<a class="button button--ghost" href={withBase(record.assetUrls.cpp)}>Raw C++</a>
			{record.assetUrls.meta ? (
				<a class="button button--ghost" href={withBase(record.assetUrls.meta)}>
					Meta JSON
				</a>
			) : null}
		</div>
	</section>

	<section class="cp-content cp-content--statement panel" id="problem-statement">
		<div class="cp-content__header">
			<div>
				<span class="section-label">Problem statement</span>
				<h2>Problem Statement</h2>
				<p>{statementDescription}</p>
			</div>
			<div class="cp-content__actions">
				{record.assetUrls.statementText ? (
					<a class="button button--ghost" href={withBase(record.assetUrls.statementText)}>
						Raw text
					</a>
				) : null}
				{record.assetUrls.statementPdf ? (
					<a class="button button--ghost" href={withBase(record.assetUrls.statementPdf)}>
						Statement PDF
					</a>
				) : null}
				{!record.assetUrls.statementText && !record.assetUrls.statementPdf ? (
					<a class="button button--ghost" href={withBase(record.assetUrls.tex)}>
						Raw TeX
					</a>
				) : null}
			</div>
		</div>

		{
			record.hasStatementText && sources.statementText ? (
				<pre class="cp-statement__plain"><code>{sources.statementText}</code></pre>
			) : statementFromTex ? (
				<>
					{statementFromTex.usedFallback ? (
						<p class="cp-content__notice">
							The statement section falls back to raw TeX display because the copied source could not
							be normalized safely.
						</p>
					) : null}
					<div class="cp-content__body" data-cp-math-content set:html={statementFromTex.html} />
				</>
			) : (
				<p class="cp-content__notice">
					The statement is not mirrored as a separate asset in this archive. The editorial and source
					files remain available below.
				</p>
			)
		}
	</section>

	<CompetitiveProgrammingEditorial
		html={editorial.html}
		rawUrl={record.assetUrls.tex}
		usedFallback={editorial.usedFallback}
	/>

	<CompetitiveProgrammingSourceTabs
		rootId={`cp-code-${record.id}`}
		sectionId="code"
		sectionLabel="Source code"
		title="Code"
		description="Exact copied C++ implementation from solution.cpp."
		tabs={[
			{
				id: 'cpp',
				label: 'C++',
				description: 'Exact copied implementation source.',
				path: record.sourcePaths.cpp,
				rawUrl: record.assetUrls.cpp,
				languageClass: 'language-cpp',
				source: sources.cpp,
			},
		]}
	/>

	<CompetitiveProgrammingSourceTabs
		rootId={`cp-source-${record.id}`}
		sectionId="source-files"
		sectionLabel="Source files"
		title="Source Files"
		description="Exact copied source-of-truth files. Edit solution.tex for the write-up and solution.cpp for the implementation."
		tabs={[
			{
				id: 'tex',
				label: 'TeX write-up',
				description: 'Exact copied write-up source.',
				path: record.sourcePaths.tex,
				rawUrl: record.assetUrls.tex,
				languageClass: 'language-latex',
				source: sources.tex,
			},
			{
				id: 'cpp',
				label: 'C++ implementation',
				description: 'Exact copied implementation source.',
				path: record.sourcePaths.cpp,
				rawUrl: record.assetUrls.cpp,
				languageClass: 'language-cpp',
				source: sources.cpp,
			},
		]}
	/>

	<CompetitiveProgrammingPagination previous={previousRecord} next={nextRecord} />
</PostLayout>
