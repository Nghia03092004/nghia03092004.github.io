---
import CompetitiveProgrammingEditorial from '../../../../features/competitive-programming/components/CompetitiveProgrammingEditorial.astro';
import CompetitiveProgrammingPagination from '../../../../features/competitive-programming/components/CompetitiveProgrammingPagination.astro';
import CompetitiveProgrammingResources from '../../../../features/competitive-programming/components/CompetitiveProgrammingResources.astro';
import CompetitiveProgrammingSourceTabs from '../../../../features/competitive-programming/components/CompetitiveProgrammingSourceTabs.astro';
import CompetitiveProgrammingStatement from '../../../../features/competitive-programming/components/CompetitiveProgrammingStatement.astro';
import {
	getCompetitiveProgrammingRecord,
	getCompetitiveProgrammingRecords,
	getCompetitiveProgrammingSources,
	type CompetitiveProgrammingTrack,
} from '../../../../features/competitive-programming/lib/competitive-programming';
import {
	extractLatexDocument,
	renderLatexContent,
} from '../../../../features/competitive-programming/lib/latex-editorial';
import { parseStatementText } from '../../../../features/competitive-programming/lib/statement-text';
import PostLayout from '../../../../layouts/PostLayout.astro';
import { withBase } from '../../../../lib/paths';

export async function getStaticPaths() {
	const records = await getCompetitiveProgrammingRecords();

	return records.map((record) => ({
		params: {
			track: record.track,
			year: String(record.year),
			slug: record.slug,
		},
	}));
}

const trackParam = Astro.params.track;
if (trackParam !== 'icpc' && trackParam !== 'ioi') {
	throw new Error(`Unsupported competitive programming track: ${trackParam}`);
}

const year = Number(Astro.params.year);
if (!Number.isInteger(year)) {
	throw new Error(`Invalid competitive programming year: ${Astro.params.year}`);
}

const slug = Astro.params.slug;
if (!slug) {
	throw new Error('Missing competitive programming slug.');
}

const track = trackParam as CompetitiveProgrammingTrack;
const record = await getCompetitiveProgrammingRecord(track, year, slug);
if (!record) {
	throw new Error(`Competitive programming entry not found for ${track}/${year}/${slug}.`);
}

const [trackRecords, sources] = await Promise.all([
	getCompetitiveProgrammingRecords(track),
	getCompetitiveProgrammingSources(record),
]);

const latexDocument = extractLatexDocument(sources.tex);
const parsedStatement =
	record.hasStatementText && sources.statementText
		? parseStatementText(sources.statementText, { title: record.title })
		: undefined;
const statementFromTex =
	!record.hasStatementText && latexDocument.statementSource
		? renderLatexContent(latexDocument.statementSource, {
				headingDepthOffset: 2,
				headingSlugPrefix: `cp-statement-${record.id}`,
			})
		: undefined;
const editorial = renderLatexContent(latexDocument.editorialSource || latexDocument.body, {
	headingDepthOffset: 2,
	headingSlugPrefix: `cp-editorial-${record.id}`,
});
const summary = record.statementPreview ?? record.description;
const statementSummary = record.hasStatementText
	? 'Formatted from the contest statement text, with sample tests broken out into copyable blocks.'
	: statementFromTex
		? `Rendered from the "${latexDocument.statementTitle ?? 'Problem Statement'}" section in the LaTeX write-up.`
		: 'No standalone statement file is available for this entry.';
const yearRecords = trackRecords.filter((entry) => entry.year === record.year);
const currentIndex = yearRecords.findIndex((entry) => entry.id === record.id);
const previousRecord = currentIndex > 0 ? yearRecords[currentIndex - 1] : undefined;
const nextRecord =
	currentIndex >= 0 && currentIndex < yearRecords.length - 1 ? yearRecords[currentIndex + 1] : undefined;
const yearPagePath = `/competitive-programming/${record.track}/${record.year}`;

const headings = [
	{ depth: 2, slug: 'problem-statement', text: 'Problem Statement' },
	{ depth: 2, slug: 'editorial', text: 'Editorial' },
	...editorial.headings,
	{ depth: 2, slug: 'code', text: 'Code' },
	{ depth: 2, slug: 'source-files', text: 'Source Files and Assets' },
];

const tags = [
	'TeX',
	'C++',
	...(record.hasStatementText ? ['Statement text'] : []),
	...(record.hasStatementPdf ? ['Statement PDF'] : []),
	...(!record.hasStatementText && statementFromTex ? ['Rendered statement'] : []),
];

const metaItems = [
	{ label: 'Track', value: record.trackLabel },
	{ label: 'Year', value: String(record.year) },
	{
		label: 'Statement',
		value: record.hasStatementText
			? record.hasStatementPdf
				? 'Text + PDF'
				: 'Text'
			: statementFromTex
				? 'Rendered from TeX'
				: 'Not mirrored',
	},
];

const primaryLink = {
	label: `Browse ${record.trackLabel} ${record.year}`,
	href: withBase(yearPagePath),
};

const secondaryLinks = [
	{
		label: `All ${record.trackLabel}`,
		href: withBase(`/competitive-programming/${record.track}`),
	},
	...(record.assetUrls.statementPdf
		? [{ label: 'Statement PDF', href: withBase(record.assetUrls.statementPdf) }]
		: []),
	...(record.assetUrls.yearPacket
		? [{ label: 'Contest packet', href: withBase(record.assetUrls.yearPacket) }]
		: []),
];

const resourceLinks = [
	{
		label: 'TeX write-up',
		href: record.assetUrls.tex,
		path: record.sourcePaths.tex,
	},
	{
		label: 'C++ implementation',
		href: record.assetUrls.cpp,
		path: record.sourcePaths.cpp,
	},
	...(record.assetUrls.statementText
		? [
				{
					label: 'Statement text',
					href: record.assetUrls.statementText,
					path: record.sourcePaths.statementText,
				},
			]
		: []),
	...(record.assetUrls.statementPdf
		? [
				{
					label: 'Statement PDF',
					href: record.assetUrls.statementPdf,
					path: record.sourcePaths.statementPdf,
				},
			]
		: []),
	...(record.assetUrls.meta
		? [
				{
					label: 'Metadata',
					href: record.assetUrls.meta,
					path: record.sourcePaths.meta,
				},
			]
		: []),
	...(record.assetUrls.yearPacket
		? [
				{
					label: 'Year packet',
					href: record.assetUrls.yearPacket,
					path: record.sourcePaths.yearPacket,
				},
			]
		: []),
];
---

<PostLayout
	title={record.displayTitle}
	description={summary}
	published={record.updated}
	publishedLabel="Updated"
	eyebrow={`${record.trackLabel} ${record.year}`}
	backHref={yearPagePath}
	backLabel={`${record.trackLabel} ${record.year}`}
	tags={tags}
	metaItems={metaItems}
	headings={headings}
	primaryLink={primaryLink}
	secondaryLinks={secondaryLinks}
>
	<CompetitiveProgrammingStatement
		rootId={`cp-statement-${record.id}`}
		description={statementSummary}
		parsedStatement={parsedStatement}
		statementHtml={statementFromTex?.html}
		usedFallback={statementFromTex?.usedFallback}
		rawTextUrl={record.assetUrls.statementText}
		statementPdfUrl={record.assetUrls.statementPdf}
		texUrl={record.assetUrls.tex}
	/>

	<CompetitiveProgrammingEditorial
		html={editorial.html}
		rawUrl={record.assetUrls.tex}
		usedFallback={editorial.usedFallback}
	/>

	<CompetitiveProgrammingSourceTabs
		rootId={`cp-code-${record.id}`}
		sectionId="code"
		sectionLabel="Implementation"
		title="Code"
		description="C++ solution used for this page."
		showPaths={false}
		tabs={[
			{
				id: 'cpp',
				label: 'C++',
				description: 'Clean code view with a raw-file link when you want the original source.',
				path: record.sourcePaths.cpp,
				rawUrl: record.assetUrls.cpp,
				languageClass: 'language-cpp',
				source: sources.cpp,
			},
		]}
	/>

	<CompetitiveProgrammingResources links={resourceLinks} />

	<CompetitiveProgrammingPagination previous={previousRecord} next={nextRecord} />
</PostLayout>
