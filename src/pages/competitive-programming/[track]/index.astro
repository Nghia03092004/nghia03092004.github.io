---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { formatDate } from '../../../lib/content';
import { withBase } from '../../../lib/paths';
import {
	getCompetitiveProgrammingRecords,
	getCompetitiveProgrammingTrackSummary,
	getCompetitiveProgrammingYearGroups,
	type CompetitiveProgrammingTrack,
} from '../../../features/competitive-programming/lib/competitive-programming';

const TRACK_COPY: Record<
	CompetitiveProgrammingTrack,
	{
		title: string;
		description: string;
		yearIntro: string;
	}
> = {
	icpc: {
		title: 'ICPC',
		description:
			'World Finals problems with statement resources when they are available, plus rendered editorials and C++ solutions.',
		yearIntro:
			'Browse by contest year first. Each year page collects the full set of problems and links out to individual solution pages.',
	},
	ioi: {
		title: 'IOI',
		description:
			'IOI task write-ups and implementations, organized by year so the archive reads like a contest history instead of a flat file dump.',
		yearIntro:
			'Each year page is the main entry point: open a year, then jump to the task you want.',
	},
};

export async function getStaticPaths() {
	return [{ params: { track: 'icpc' } }, { params: { track: 'ioi' } }];
}

const trackParam = Astro.params.track;
if (trackParam !== 'icpc' && trackParam !== 'ioi') {
	throw new Error(`Unsupported competitive programming track: ${trackParam}`);
}

const track = trackParam as CompetitiveProgrammingTrack;
const [summary, records, yearGroups] = await Promise.all([
	getCompetitiveProgrammingTrackSummary(track),
	getCompetitiveProgrammingRecords(track),
	getCompetitiveProgrammingYearGroups(track),
]);
const latestUpdated = [...records].sort((left, right) => right.updated.getTime() - left.updated.getTime())[0]?.updated;
const latestEntries = [...records].sort((left, right) => right.updated.getTime() - left.updated.getTime()).slice(0, 6);
const copy = TRACK_COPY[track];
---

<BaseLayout title={summary.longLabel} description={copy.description}>
	<section class="page-intro cp-intro">
		<span class="eyebrow">Competitive Programming</span>
		<h1>{copy.title}</h1>
		<p>{copy.description}</p>
		<div class="archive-summary">
			<div class="archive-summary__item">
				<strong>{summary.entryCount}</strong>
				<span>problem pages</span>
			</div>
			<div class="archive-summary__item">
				<strong>{summary.yearCount}</strong>
				<span>contest years</span>
			</div>
			<div class="archive-summary__item">
				<strong>{track === 'icpc' ? summary.statementTextCount : summary.entryCount}</strong>
				<span>{track === 'icpc' ? 'statement texts available' : 'write-ups in the archive'}</span>
			</div>
			<div class="archive-summary__item">
				<strong>{latestUpdated ? formatDate(latestUpdated) : 'n/a'}</strong>
				<span>most recently updated entry</span>
			</div>
		</div>
		<div class="chip-row">
			<a class="button" href={withBase('/competitive-programming')}>All competitive programming</a>
			<a class="button button--ghost" href={withBase('/project-euler')}>Project Euler</a>
		</div>
	</section>

	<section class="section-panel">
		<div class="section-heading">
			<div>
				<span class="section-label">Browse by year</span>
				<h2>Contest years</h2>
				<p>{copy.yearIntro}</p>
			</div>
		</div>

		<div class="cp-year-grid">
			{
				yearGroups.map((group) => (
					<article class="cp-year-card cp-year-card--browse">
						<div class="cp-year-card__topline">
							<div>
								<strong>{group.year}</strong>
								<span>{group.entryCount} problems</span>
							</div>
							<span class="chip" data-tone={track === 'icpc' ? 'warm' : 'cool'}>
								{track.toUpperCase()}
							</span>
						</div>

						<p class="cp-year-card__summary">
							{track === 'icpc'
								? `${group.statementTextCount} statement texts and ${group.statementPdfCount} PDFs are mirrored for this year.`
								: 'Each task keeps the editorial and the C++ implementation on one page.'}
						</p>

						<ul class="cp-year-card__list">
							{group.records.slice(0, 4).map((record) => <li>{record.displayTitle}</li>)}
						</ul>

						<div class="cp-year-card__actions">
							<a class="button" href={withBase(`/competitive-programming/${track}/${group.year}`)}>
								Browse {group.year}
							</a>
							{group.packetUrl ? (
								<a class="button button--ghost" href={withBase(group.packetUrl)}>
									Contest packet
								</a>
							) : null}
						</div>
					</article>
				))
			}
		</div>
	</section>

	<section class="section-panel section-panel--signal">
		<div class="section-heading">
			<div>
				<span class="section-label">Recent solutions</span>
				<h2>Recently updated problem pages</h2>
				<p>These are the latest entries touched in this track, surfaced without taking over the main browse flow.</p>
			</div>
		</div>
		<div class="signal-grid">
			{
				latestEntries.map((record, index) => (
					<a
						class="signal-card"
						data-tone={track === 'icpc' ? 'warm' : 'cool'}
						href={withBase(`/competitive-programming/${record.track}/${record.year}/${record.slug}`)}
					>
						<span class="signal-card__index">0{index + 1}</span>
						<div>
							<span class="eyebrow">{record.year}</span>
							<h3>{record.displayTitle}</h3>
							<p>{record.statementPreview ?? record.description}</p>
						</div>
						<div class="signal-card__meta">
							<span class="metric">{formatDate(record.updated)}</span>
							<span class="metric">{record.hasStatementText ? 'statement + editorial + code' : 'editorial + code'}</span>
						</div>
					</a>
				))
			}
		</div>
	</section>
</BaseLayout>
