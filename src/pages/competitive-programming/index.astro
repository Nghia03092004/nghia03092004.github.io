---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate } from '../../lib/content';
import { withBase } from '../../lib/paths';
import {
	getCompetitiveProgrammingRecords,
	getCompetitiveProgrammingTrackSummaries,
	getCompetitiveProgrammingYearGroups,
} from '../../features/competitive-programming/lib/competitive-programming';

const [summaries, allRecords, icpcYears, ioiYears] = await Promise.all([
	getCompetitiveProgrammingTrackSummaries(),
	getCompetitiveProgrammingRecords(),
	getCompetitiveProgrammingYearGroups('icpc'),
	getCompetitiveProgrammingYearGroups('ioi'),
]);
const totalEntries = summaries.reduce((sum, summary) => sum + summary.entryCount, 0);
const totalYears = summaries.reduce((sum, summary) => sum + summary.yearCount, 0);
const latestUpdated = [...allRecords].sort((left, right) => right.updated.getTime() - left.updated.getTime())[0]?.updated;
const featuredYears = [...icpcYears, ...ioiYears]
	.sort((left, right) => {
		if (left.year !== right.year) {
			return right.year - left.year;
		}

		return left.track.localeCompare(right.track);
	})
	.slice(0, 6);
const latestEntries = [...allRecords].sort((left, right) => right.updated.getTime() - left.updated.getTime()).slice(0, 6);
---

<BaseLayout
	title="Competitive Programming"
	description="ICPC and IOI solutions organized by track, year, and problem."
>
	<section class="page-intro cp-intro">
		<span class="eyebrow">Competitive Programming</span>
		<h1>ICPC and IOI, organized to browse like a real archive.</h1>
		<p>
			This section collects contest problems I wanted to keep in a usable form: statement, editorial,
			code, and raw files together on one page. The main path is simple: pick a track, then a year,
			then a problem.
		</p>
		<div class="archive-summary">
			<div class="archive-summary__item">
				<strong>{totalEntries}</strong>
				<span>problem pages</span>
			</div>
			<div class="archive-summary__item">
				<strong>{summaries.length}</strong>
				<span>contest tracks</span>
			</div>
			<div class="archive-summary__item">
				<strong>{totalYears}</strong>
				<span>contest years</span>
			</div>
			<div class="archive-summary__item">
				<strong>{latestUpdated ? formatDate(latestUpdated) : 'n/a'}</strong>
				<span>most recently updated entry</span>
			</div>
		</div>
	</section>

	<section class="section-panel">
		<div class="section-heading">
			<div>
				<span class="section-label">Tracks</span>
				<h2>Start with a contest track</h2>
				<p>Each track has its own year-by-year landing page, so the archive is easy to scan without opening raw folders.</p>
			</div>
		</div>
		<div class="track-grid">
			{
				summaries.map((summary, index) => (
					<a
						class="card track-card"
						data-tone={summary.track === 'icpc' ? 'warm' : 'cool'}
						href={withBase(`/competitive-programming/${summary.track}`)}
					>
						<span class="track-card__index">0{index + 1}</span>
						<span class="eyebrow">{summary.label}</span>
						<h3>{summary.longLabel}</h3>
						<p>
							{summary.entryCount} problems across {summary.yearCount} years.
							{summary.track === 'icpc'
								? ` ${summary.statementTextCount} statement texts and ${summary.statementPdfCount} PDFs are mirrored in the archive.`
								: ' Each task page centers the write-up and code.'}
						</p>
						<span class="track-card__link">Browse {summary.label}</span>
					</a>
				))
			}
		</div>
	</section>

	<section class="section-panel">
		<div class="section-heading">
			<div>
				<span class="section-label">Browse by year</span>
				<h2>Recent contest years</h2>
				<p>The year page is the main browsing layer: it lists the problems, resource badges, and direct links to each solution page.</p>
			</div>
		</div>

		<div class="cp-year-grid">
			{
				featuredYears.map((group) => (
					<article class="cp-year-card cp-year-card--browse">
						<div class="cp-year-card__topline">
							<div>
								<strong>{group.year}</strong>
								<span>{group.entryCount} problems</span>
							</div>
							<span class="chip" data-tone={group.track === 'icpc' ? 'warm' : 'cool'}>
								{group.track.toUpperCase()}
							</span>
						</div>
						<p class="cp-year-card__summary">
							{group.track === 'icpc'
								? `${group.statementTextCount} statement texts and ${group.statementPdfCount} PDFs are available for this year.`
								: 'Task pages are grouped here by year before you drill down into an individual problem.'}
						</p>
						<ul class="cp-year-card__list">
							{group.records.slice(0, 4).map((record) => <li>{record.displayTitle}</li>)}
						</ul>
						<div class="cp-year-card__actions">
							<a class="button" href={withBase(`/competitive-programming/${group.track}/${group.year}`)}>
								Browse {group.track.toUpperCase()} {group.year}
							</a>
							{group.packetUrl ? (
								<a class="button button--ghost" href={withBase(group.packetUrl)}>
									Contest packet
								</a>
							) : null}
						</div>
					</article>
				))
			}
		</div>
	</section>

	<section class="section-panel section-panel--signal">
		<div class="section-heading">
			<div>
				<span class="section-label">Recent additions</span>
				<h2>Recently updated problem pages</h2>
				<p>These stay secondary to the track/year browse flow, but they are still useful when you want to see what changed most recently.</p>
			</div>
		</div>
		<div class="signal-grid">
			{
				latestEntries.map((record, index) => (
					<a
						class="signal-card"
						data-tone={record.track === 'icpc' ? 'warm' : 'cool'}
						href={withBase(`/competitive-programming/${record.track}/${record.year}/${record.slug}`)}
					>
						<span class="signal-card__index">0{index + 1}</span>
						<div>
							<span class="eyebrow">
								{record.track.toUpperCase()} {record.year}
							</span>
							<h3>{record.displayTitle}</h3>
							<p>{record.statementPreview ?? record.description}</p>
						</div>
						<div class="signal-card__meta">
							<span class="metric">{formatDate(record.updated)}</span>
							<span class="metric">{record.hasStatementText ? 'statement + editorial + code' : 'editorial + code'}</span>
						</div>
					</a>
				))
			}
		</div>
	</section>
</BaseLayout>
