---
import { render } from 'astro:content';

import SourceTabs from '../../components/SourceTabs.astro';
import PostLayout from '../../layouts/PostLayout.astro';
import {
	formatEulerSolvedByCount,
	formatProblemNumber,
	getEulerProblemUrl,
	getEulerRecord,
	getEulerRecords,
	getEulerSources,
} from '../../lib/euler';

export async function getStaticPaths() {
	const entries = await getEulerRecords();
	return entries.map((entry) => ({ params: { slug: entry.id } }));
}

const slug = Astro.params.slug;
if (!slug) {
	throw new Error('Missing Project Euler slug.');
}

const record = await getEulerRecord(slug);
if (!record) {
	throw new Error(`Project Euler entry not found for slug "${slug}".`);
}

const { Content, headings } = await render(record.entry);
const sources = await getEulerSources(record.problem);

const metaItems = [
	{ label: 'Problem', value: formatProblemNumber(record.problem) },
	{ label: 'Level', value: record.difficultyLabel },
	...(record.solvedByCount
		? [{ label: 'Solved By', value: formatEulerSolvedByCount(record.solvedByCount) }]
		: []),
	{ label: 'Languages', value: record.languages.join(', ') },
	...(record.answer ? [{ label: 'Answer', value: record.answer }] : []),
	{ label: 'Length', value: `${record.wordCount.toLocaleString()} words` },
];
---

<PostLayout
	title={record.title}
	description={record.description}
	published={record.updated}
	publishedLabel="Source sync"
	eyebrow="Project Euler"
	backHref="/project-euler"
	backLabel="All Euler problems"
	tags={[record.difficultyLabel, 'full solution', ...record.languages]}
	metaItems={metaItems}
	headings={headings}
	primaryLink={{ label: 'View original problem', href: getEulerProblemUrl(record.problem) }}
	secondaryLinks={[
		{ label: 'Jump to C++', href: '#cpp-source' },
		{ label: 'Jump to Python', href: '#python-source' },
	]}
>
	<Content />
	<SourceTabs
		problem={record.problem}
		cppSource={sources.cpp}
		pythonSource={sources.python}
		cppPath={record.sourcePaths.cpp}
		pythonPath={record.sourcePaths.python}
	/>
</PostLayout>
