---
import { render } from 'astro:content';

import ProjectEulerPagination from '../../features/project-euler/components/ProjectEulerPagination.astro';
import ProjectEulerStatement from '../../features/project-euler/components/ProjectEulerStatement.astro';
import ProjectEulerSourceTabs from '../../features/project-euler/components/ProjectEulerSourceTabs.astro';
import PostLayout from '../../layouts/PostLayout.astro';
import {
	formatEulerSolvedByCount,
	formatProblemNumber,
	getEulerProblemUrl,
	getEulerRecord,
	getEulerRecords,
	getEulerSources,
} from '../../features/project-euler/lib/euler';
import { getEulerMirroredStatement } from '../../features/project-euler/lib/euler-statement';

export async function getStaticPaths() {
	const entries = await getEulerRecords();
	return entries.map((entry) => ({ params: { slug: entry.id } }));
}

const slug = Astro.params.slug;
if (!slug) {
	throw new Error('Missing Project Euler slug.');
}

const record = await getEulerRecord(slug);
if (!record) {
	throw new Error(`Project Euler entry not found for slug "${slug}".`);
}

const { Content, headings } = await render(record.entry);
const allRecords = await getEulerRecords();
const sources = await getEulerSources(record.problem);
const mirroredStatement = record.hasMirroredStatement
	? await getEulerMirroredStatement(record.problem)
	: undefined;
const currentIndex = allRecords.findIndex((entry) => entry.id === record.id);
const previousRecord = currentIndex > 0 ? allRecords[currentIndex - 1] : undefined;
const nextRecord = currentIndex >= 0 && currentIndex < allRecords.length - 1 ? allRecords[currentIndex + 1] : undefined;
const tocHeadings = [
	...(mirroredStatement ? [{ depth: 2, slug: 'problem-statement', text: 'Problem Statement' }] : []),
	...headings,
	{ depth: 2, slug: 'code', text: 'Code' },
];

const metaItems = [
	{ label: 'Problem', value: formatProblemNumber(record.problem) },
	{ label: 'Level', value: record.difficultyLabel },
	...(record.solvedByCount
		? [{ label: 'Solved By', value: formatEulerSolvedByCount(record.solvedByCount) }]
		: []),
	{ label: 'Languages', value: record.languages.join(', ') },
	...(record.answer ? [{ label: 'Answer', value: record.answer }] : []),
	{ label: 'Length', value: `${record.wordCount.toLocaleString()} words` },
];
---

<PostLayout
	title={record.title}
	description={record.description}
	published={record.updated}
	publishedLabel="Source sync"
	eyebrow="Project Euler"
	backHref="/project-euler"
	backLabel="All Euler problems"
	tags={record.tags}
	metaItems={metaItems}
	headings={tocHeadings}
	primaryLink={{ label: 'View original problem', href: getEulerProblemUrl(record.problem) }}
	secondaryLinks={[
		{ label: 'Jump to Code', href: '#code' },
		{ label: 'Jump to Python', href: '#python-source' },
	]}
>
	{mirroredStatement ? <ProjectEulerStatement problem={record.problem} statement={mirroredStatement} /> : null}
	<Content />
	<ProjectEulerSourceTabs
		problem={record.problem}
		cppSource={sources.cpp}
		pythonSource={sources.python}
		cppPath={record.sourcePaths.cpp}
		pythonPath={record.sourcePaths.python}
	/>
	<ProjectEulerPagination previous={previousRecord} next={nextRecord} />
</PostLayout>
