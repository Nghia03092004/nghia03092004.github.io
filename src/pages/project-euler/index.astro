---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate } from '../../lib/content';
import {
	formatEulerDifficultyLevel,
	formatEulerSolvedByCount,
	formatProblemNumber,
	getEulerDifficultySnapshotDate,
	getEulerDifficultyColor,
	getEulerDifficultyInk,
	getEulerProblemUrl,
	getEulerRecords,
} from '../../lib/euler';
import { withBase } from '../../lib/paths';

const entries = await getEulerRecords();
const entriesByProblem = [...entries].sort((left, right) => left.problem - right.problem);
const latestUpdated = [...entries].sort((a, b) => b.updated.getTime() - a.updated.getTime())[0];
const previewEntry = entriesByProblem[0];
const maxDifficultyLevel = Math.max(...entriesByProblem.map((entry) => entry.difficultyLevel), 0);
const difficultySnapshotDate = getEulerDifficultySnapshotDate();
const legendLevels = [
	0,
	Math.round(maxDifficultyLevel * 0.25),
	Math.round(maxDifficultyLevel * 0.5),
	Math.round(maxDifficultyLevel * 0.75),
	maxDifficultyLevel,
].filter((level, index, list) => list.indexOf(level) === index);
const getLevelStyle = (level: number) =>
	`--level-color: ${getEulerDifficultyColor(level, maxDifficultyLevel)}; --level-ink: ${getEulerDifficultyInk(level, maxDifficultyLevel)};`;

const getBand = (problem: number) => {
	if (problem <= 100) return '001-100';
	if (problem <= 300) return '101-300';
	if (problem <= 600) return '301-600';
	return '601-988';
};

const getSearchText = (entry: (typeof entriesByProblem)[number]) =>
	`${formatProblemNumber(entry.problem)} ${entry.title} ${entry.description} ${entry.answer ?? ''}`
		.toLowerCase()
		.trim();
---

<BaseLayout
	title="Project Euler"
	description="A searchable Project Euler archive with a problem heatmap, full writeups, and source code."
>
	<section class="page-intro euler-intro">
		<span class="eyebrow">Project Euler</span>
		<h1>A Project Euler heatmap with cleaner browsing.</h1>
		<p>
			The archive now starts with a dense clickable problem board, then a compact result list
			below it. Use search when you know what you want, or scan the heatmap when you do not.
		</p>
		<div class="archive-summary">
			<div class="archive-summary__item">
				<strong>{entries.length}</strong>
				<span>problems on the board</span>
			</div>
			<div class="archive-summary__item">
				<strong>{entries.length * 2}</strong>
				<span>C++ and Python files linked from entries</span>
			</div>
			<div class="archive-summary__item">
				<strong>{latestUpdated ? formatDate(latestUpdated.updated) : 'n/a'}</strong>
				<span>newest archive sync</span>
			</div>
		</div>
	</section>

	<section class="euler-archive" data-euler-root>
		<div class="panel archive-toolbar">
			<div class="archive-toolbar__copy">
				<span class="section-label">Browse</span>
				<h2>Search, scan, then open the full solution.</h2>
				<p>
					The heatmap keeps the archive dense and fast. Hover any problem to preview it, then
					open the writeup when you want the full proof and code.
				</p>
				<p class="archive-toolbar__note">
					Levels are now ranked from Project Euler&apos;s public <em>Solved By</em> counts
					snapshot from {formatDate(difficultySnapshotDate)}, then grouped into 25-problem
					<em>Level NN</em> bands to mirror the official heatmap style.
				</p>
			</div>

			<form class="filter-bar archive-toolbar__filters" aria-label="Problem filters">
				<input
					class="filter-input"
					type="search"
					name="query"
					placeholder="Search by problem number, title, or answer"
				/>
				<select class="filter-select" name="band">
					<option value="all">All ranges</option>
					<option value="001-100">001-100</option>
					<option value="101-300">101-300</option>
					<option value="301-600">301-600</option>
					<option value="601-988">601-988</option>
				</select>
				<select class="filter-select" name="sort">
					<option value="problem-asc">Problem number: low to high</option>
					<option value="problem-desc">Problem number: high to low</option>
					<option value="level-asc">Level: low to high</option>
					<option value="level-desc">Level: high to low</option>
					<option value="updated-desc">Updated: newest first</option>
					<option value="title-asc">Title: A to Z</option>
				</select>
			</form>
		</div>

		<div class="heatmap-layout">
			<div class="panel heatmap-panel">
				<div class="heatmap-panel__header">
					<div>
						<span class="section-label">Problem board</span>
						<h2>Every solved problem in one board</h2>
					</div>

					<div class="heatmap-legend" aria-hidden="true">
						<span class="metric">{formatEulerDifficultyLevel(legendLevels[0] ?? 0)}</span>
						<div class="heatmap-legend__scale">
							{
								legendLevels.map((level) => (
									<span
										class="heatmap-legend__swatch"
										style={getLevelStyle(level)}
										title={formatEulerDifficultyLevel(level)}
									></span>
								))
							}
						</div>
						<span class="metric">{formatEulerDifficultyLevel(legendLevels.at(-1) ?? 0)}</span>
					</div>
				</div>

				<div class="heatmap-grid" data-heatmap-grid>
					{
						entriesByProblem.map((entry) => (
							<a
								class="heatmap-cell"
								data-heatmap-cell
								data-level={entry.difficultyLevel}
								data-level-label={entry.difficultyLabel}
								data-level-color={entry.difficultyColor}
								data-level-ink={entry.difficultyInk}
								data-solved-by={entry.solvedByCount ? formatEulerSolvedByCount(entry.solvedByCount) : ''}
								data-search={getSearchText(entry)}
								data-band={getBand(entry.problem)}
								data-problem={entry.problem}
								data-updated={entry.updated.getTime()}
								data-title={entry.title}
								data-description={entry.description}
								data-answer={entry.answer ?? ''}
								style={`--level-color: ${entry.difficultyColor}; --level-ink: ${entry.difficultyInk};`}
								data-href={withBase(`/project-euler/${entry.id}`)}
								href={withBase(`/project-euler/${entry.id}`)}
								title={`${formatProblemNumber(entry.problem)} ${entry.title} (${entry.difficultyLabel})${entry.solvedByCount ? `, solved by ${formatEulerSolvedByCount(entry.solvedByCount)}` : ''}`}
							>
								<span>{entry.problem}</span>
							</a>
						))
					}
				</div>
			</div>

			{
				previewEntry ? (
					<aside class="panel heatmap-preview">
						<span class="section-label">Preview</span>
						<span class="heatmap-preview__number" data-preview-problem>
							{formatProblemNumber(previewEntry.problem)}
						</span>
						<h2 data-preview-title>{previewEntry.title}</h2>
						<p data-preview-description>{previewEntry.description}</p>

						<div class="meta-grid heatmap-preview__meta">
							<div class="meta-item">
								<strong>Level</strong>
								<span data-preview-difficulty>{previewEntry.difficultyLabel}</span>
							</div>
							<div class="meta-item">
								<strong>Solved By</strong>
								<span data-preview-solved-by>
									{previewEntry.solvedByCount ? formatEulerSolvedByCount(previewEntry.solvedByCount) : 'n/a'}
								</span>
							</div>
							<div class="meta-item">
								<strong>Updated</strong>
								<span data-preview-updated>{formatDate(previewEntry.updated)}</span>
							</div>
						</div>

						<div class="chip-row">
							<span
								class="chip chip--level"
								data-preview-difficulty-chip
								style={`--level-color: ${previewEntry.difficultyColor}; --level-ink: ${previewEntry.difficultyInk};`}
							>
								{previewEntry.difficultyLabel}
							</span>
							<span class="chip" data-tone="cool">C++</span>
							<span class="chip" data-tone="cool">Python</span>
							{previewEntry.answer ? <span class="chip" data-tone="olive">answer {previewEntry.answer}</span> : null}
						</div>

						<div class="post-actions">
							<a class="button" data-preview-link href={withBase(`/project-euler/${previewEntry.id}`)}>
								Open solution
							</a>
							<a
								class="button button--ghost"
								data-preview-original
								href={getEulerProblemUrl(previewEntry.problem)}
							>
								Original problem
							</a>
						</div>
					</aside>
				) : null
			}
		</div>

		<div class="panel archive-results" data-results-panel>
			<div class="archive-results__header">
				<div>
					<span class="section-label">Result list</span>
					<h2>Filtered entries</h2>
				</div>
				<span class="metric archive-results__count" data-result-count>
					{entries.length} results
				</span>
			</div>

			<div class="euler-list" data-result-list>
				{
					entriesByProblem.map((entry) => (
						<a
							class="euler-row"
							data-entry-row
							data-search={getSearchText(entry)}
							data-band={getBand(entry.problem)}
							data-problem={entry.problem}
							data-updated={entry.updated.getTime()}
							data-title={entry.title}
							data-description={entry.description}
							data-answer={entry.answer ?? ''}
							data-level={entry.difficultyLevel}
							data-level-label={entry.difficultyLabel}
							data-level-color={entry.difficultyColor}
							data-level-ink={entry.difficultyInk}
							data-solved-by={entry.solvedByCount ? formatEulerSolvedByCount(entry.solvedByCount) : ''}
							data-href={withBase(`/project-euler/${entry.id}`)}
							href={withBase(`/project-euler/${entry.id}`)}
						>
							<div class="euler-row__number">
								<span class="metric">{formatProblemNumber(entry.problem)}</span>
							</div>
							<div class="euler-row__body">
								<h3>{entry.title}</h3>
								<p>{entry.description}</p>
							</div>
							<div class="euler-row__meta">
								{entry.solvedByCount ? (
									<span class="metric">Solved by {formatEulerSolvedByCount(entry.solvedByCount)}</span>
								) : null}
								<span class="metric">Updated {formatDate(entry.updated)}</span>
								<span
									class="chip chip--level"
									style={`--level-color: ${entry.difficultyColor}; --level-ink: ${entry.difficultyInk};`}
								>
									{entry.difficultyLabel}
								</span>
								{entry.answer ? <span class="chip" data-tone="warm">answer {entry.answer}</span> : null}
							</div>
						</a>
					))
				}
			</div>
		</div>

		<div class="archive-empty panel" data-empty-state hidden>
			<span class="eyebrow">No match</span>
			<p class="lede">No Project Euler entries fit the current search and filter combination.</p>
		</div>
	</section>

	<script is:inline>
		const root = document.querySelector('[data-euler-root]');
		const form = root?.querySelector('form');
		const rows = Array.from(root?.querySelectorAll('[data-entry-row]') ?? []);
		const cells = Array.from(root?.querySelectorAll('[data-heatmap-cell]') ?? []);
		const resultList = root?.querySelector('[data-result-list]');
		const resultCount = root?.querySelector('[data-result-count]');
		const resultsPanel = root?.querySelector('[data-results-panel]');
		const emptyState = root?.querySelector('[data-empty-state]');

		const previewRefs = {
			problem: root?.querySelector('[data-preview-problem]'),
			title: root?.querySelector('[data-preview-title]'),
			description: root?.querySelector('[data-preview-description]'),
			difficulty: root?.querySelector('[data-preview-difficulty]'),
			difficultyChip: root?.querySelector('[data-preview-difficulty-chip]'),
			solvedBy: root?.querySelector('[data-preview-solved-by]'),
			updated: root?.querySelector('[data-preview-updated]'),
			link: root?.querySelector('[data-preview-link]'),
			original: root?.querySelector('[data-preview-original]'),
		};

		const sorters = {
			'problem-asc': (left, right) => Number(left.dataset.problem) - Number(right.dataset.problem),
			'problem-desc': (left, right) => Number(right.dataset.problem) - Number(left.dataset.problem),
			'level-asc': (left, right) => Number(left.dataset.level) - Number(right.dataset.level),
			'level-desc': (left, right) => Number(right.dataset.level) - Number(left.dataset.level),
			'updated-desc': (left, right) => Number(right.dataset.updated) - Number(left.dataset.updated),
			'title-asc': (left, right) =>
				(left.dataset.title ?? '').localeCompare(right.dataset.title ?? ''),
		};

		const formatProblem = (problem) => `#${String(problem).padStart(4, '0')}`;

		const updatePreview = (element) => {
			if (!element || !previewRefs.problem) return;

			const problem = Number(element.dataset.problem ?? 0);
			const href = element.dataset.href ?? '#';
			const levelLabel = element.dataset.levelLabel ?? 'Level 00';
			const levelColor = element.dataset.levelColor ?? 'rgba(190, 218, 164, 0.9)';
			const levelInk = element.dataset.levelInk ?? 'var(--ink)';
			const solvedBy = element.dataset.solvedBy ?? '';
			const updated = Number(element.dataset.updated ?? 0);

			previewRefs.problem.textContent = formatProblem(problem);
			if (previewRefs.title) previewRefs.title.textContent = element.dataset.title ?? '';
			if (previewRefs.description) {
				previewRefs.description.textContent = element.dataset.description ?? '';
			}
			if (previewRefs.difficulty) previewRefs.difficulty.textContent = levelLabel;
			if (previewRefs.difficultyChip) {
				previewRefs.difficultyChip.textContent = levelLabel;
				previewRefs.difficultyChip.style.setProperty('--level-color', levelColor);
				previewRefs.difficultyChip.style.setProperty('--level-ink', levelInk);
			}
			if (previewRefs.solvedBy) {
				previewRefs.solvedBy.textContent = solvedBy || 'n/a';
			}
			if (previewRefs.updated && updated) {
				previewRefs.updated.textContent = new Date(updated).toLocaleDateString('en', {
					year: 'numeric',
					month: 'short',
					day: 'numeric',
				});
			}
			if (previewRefs.link) previewRefs.link.setAttribute('href', href);
			if (previewRefs.original) {
				previewRefs.original.setAttribute('href', `https://projecteuler.net/problem=${problem}`);
			}
		};

		const matchesFilters = (element, query, band) =>
			(!query || (element.dataset.search ?? '').includes(query)) &&
			(band === 'all' || element.dataset.band === band);

		const applyFilters = () => {
			if (!form || !resultList) return;

			const query = form.elements.namedItem('query')?.value?.toLowerCase().trim() ?? '';
			const band = form.elements.namedItem('band')?.value ?? 'all';
			const sort = form.elements.namedItem('sort')?.value ?? 'problem-asc';
			const hasFilter = Boolean(query) || band !== 'all';

			const visibleRows = rows.filter((row) => matchesFilters(row, query, band));

			rows.forEach((row) => {
				const visible = visibleRows.includes(row);
				row.hidden = !visible;
			});

			cells.forEach((cell) => {
				const match = matchesFilters(cell, query, band);
				cell.classList.toggle('is-muted', !match);
				cell.classList.toggle('is-match', match && hasFilter);
			});

			visibleRows
				.slice()
				.sort(sorters[sort] ?? sorters['problem-asc'])
				.forEach((row) => {
					resultList.appendChild(row);
				});

			if (resultCount) {
				resultCount.textContent = `${visibleRows.length} ${visibleRows.length === 1 ? 'result' : 'results'}`;
			}

			if (resultsPanel) {
				resultsPanel.hidden = visibleRows.length === 0;
			}

			if (emptyState) {
				emptyState.hidden = visibleRows.length !== 0;
			}

			const previewTarget = visibleRows[0] ?? cells.find((cell) => matchesFilters(cell, query, band));
			if (previewTarget) {
				updatePreview(previewTarget);
			}
		};

		[...cells, ...rows].forEach((element) => {
			element.addEventListener('mouseenter', () => updatePreview(element));
			element.addEventListener('focus', () => updatePreview(element));
		});

		form?.addEventListener('input', applyFilters);
		form?.addEventListener('change', applyFilters);
		applyFilters();
	</script>
</BaseLayout>
