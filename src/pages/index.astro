---
import EulerCard from '../features/project-euler/components/EulerCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatDate } from '../lib/content';
import { formatProblemNumber, getEulerRecords } from '../features/project-euler/lib/euler';
import { withBase } from '../lib/paths';
import { focusAreas } from '../site.config';
import {
	getCompetitiveProgrammingRecords,
	getCompetitiveProgrammingTrackSummaries,
} from '../features/competitive-programming/lib/competitive-programming';

const [eulerEntries, competitiveProgrammingEntries, cpSummaries] = await Promise.all([
	getEulerRecords(),
	getCompetitiveProgrammingRecords(),
	getCompetitiveProgrammingTrackSummaries(),
]);
const featuredProblems = [1, 48, 250, 700].flatMap((problem) => {
	const entry = eulerEntries.find((item) => item.problem === problem);
	return entry ? [entry] : [];
});
const latestEulerEntries = [...eulerEntries]
	.sort((a, b) => b.updated.getTime() - a.updated.getTime())
	.slice(0, 4);
const totalEulerWords = eulerEntries.reduce((sum, entry) => sum + entry.wordCount, 0);
const totalCompetitiveProgrammingEntries = competitiveProgrammingEntries.length;
const totalSourceFiles = eulerEntries.length * 2 + totalCompetitiveProgrammingEntries * 2;
---

<BaseLayout
	title="Home"
	description="Project Euler, competitive programming, and technical notes by Ethan Pham."
>
	<section class="hero">
		<div class="panel hero-copy">
			<div class="hero-copy__topline">
				<span class="eyebrow">Personal archive</span>
				<span class="hero-copy__burst">
					{eulerEntries.length} Euler + {totalCompetitiveProgrammingEntries} competitive programming
					entries
				</span>
			</div>
			<h1>Project Euler, competitive programming, and the notes I keep around.</h1>
			<p>
				This is my personal technical site. I use it to keep Project Euler write-ups, competitive
				programming solutions, essays, and code notes in one place. Most of my time lately has gone
				into AI/ML, algorithms, algebra, and post-quantum cryptography.
			</p>
			<div class="hero-actions">
				<a class="button" href={withBase('/project-euler')}>Browse Project Euler</a>
				<a class="button button--ghost" href={withBase('/competitive-programming')}>
					Browse Competitive Programming
				</a>
			</div>
			<div class="hero-ledger">
				{focusAreas.map((item, index) => (
					<div class="hero-ledger__card">
						<span class="hero-ledger__label">Focus 0{index + 1}</span>
						<strong class="hero-ledger__value">{item}</strong>
					</div>
				))}
			</div>
		</div>

		<aside class="hero-aside">
			<div class="hero-aside__panel hero-aside__panel--warm">
				<span class="eyebrow">What lives here</span>
				<p class="lede">
					Mostly problem solving: Project Euler, ICPC, IOI, and short notes from things I am
					building or studying.
				</p>
				<p class="hero-note">
					Project Euler is the deepest part of the site. The competitive programming section is now
					organized by track, year, and problem so it is easy to browse instead of feeling like a
					folder dump.
				</p>
			</div>
			<div class="hero-aside__panel hero-aside__panel--grid">
				<span class="section-label">Archive scope</span>
				<div class="stats-grid">
					<div class="stat">
						<span class="stat__value">{eulerEntries.length}</span>
						<span class="stat__label">Euler problems</span>
					</div>
					<div class="stat">
						<span class="stat__value">{totalCompetitiveProgrammingEntries}</span>
						<span class="stat__label">CP entries</span>
					</div>
					<div class="stat">
						<span class="stat__value">{cpSummaries.length + 1}</span>
						<span class="stat__label">Major archives</span>
					</div>
					<div class="stat">
						<span class="stat__value">{Math.round(totalSourceFiles / 100) / 10}k</span>
						<span class="stat__label">Solution files</span>
					</div>
				</div>
			</div>
		</aside>
	</section>

	<div class="section-stack">
		<section class="section-panel">
			<div class="section-heading">
				<div>
					<span class="section-label">Major areas</span>
					<h2>The site has two main problem-solving archives</h2>
					<p>
						Project Euler is still the largest body of work here, and Competitive Programming now
						has its own section instead of being mixed into the repository structure.
					</p>
				</div>
			</div>
			<div class="track-grid">
				<a class="card track-card" data-tone="warm" href={withBase('/project-euler')}>
					<span class="track-card__index">01</span>
					<span class="eyebrow">Project Euler</span>
					<h3>The long-form math archive</h3>
					<p>
						{eulerEntries.length} full problems with statements, proofs, final answers, and both C++
						and Python implementations.
					</p>
					<span class="track-card__link">Browse Project Euler</span>
				</a>
				<a class="card track-card" data-tone="cool" href={withBase('/competitive-programming')}>
					<span class="track-card__index">02</span>
					<span class="eyebrow">Competitive Programming</span>
					<h3>ICPC and IOI, organized by contest year</h3>
					<p>
						{totalCompetitiveProgrammingEntries} problem pages with statement, editorial, and code
						views, plus direct links to the original files when they are useful.
					</p>
					<span class="track-card__link">Open the archive</span>
				</a>
				<a class="card track-card" data-tone="olive" href={withBase('/about')}>
					<span class="track-card__index">03</span>
					<span class="eyebrow">About</span>
					<h3>A short background on what I am working on</h3>
					<p>
						AI/ML, algorithms, algebra, post-quantum cryptography, and the kind of work I like to
						keep notes on.
					</p>
					<span class="track-card__link">Read the background</span>
				</a>
			</div>
		</section>

		<section class="section-panel section-panel--spotlight">
			<div class="section-heading">
				<div>
					<span class="section-label">Project Euler</span>
					<h2>Project Euler is still where I write the most</h2>
					<p>
						It is the longest-running part of the site, and still the best place to see full problem
						statements, proofs, and implementations together.
					</p>
				</div>
			</div>
			<div class="track-grid">
				<a class="card track-card" data-tone="warm" href={withBase('/project-euler')}>
					<span class="track-card__index">01</span>
					<span class="eyebrow">Full writeups</span>
					<h3>The math stays visible</h3>
					<p>Problem statements, proofs, algorithm notes, complexity analysis, and answers on one page.</p>
					<span class="track-card__link">Browse the archive</span>
				</a>
				<a class="card track-card" data-tone="cool" href={withBase('/project-euler/problem-0048')}>
					<span class="track-card__index">02</span>
					<span class="eyebrow">C++ source</span>
					<h3>C++ implementation next to the write-up</h3>
					<p>Every problem page exposes the exact C++ file from the local Project Euler archive.</p>
					<span class="track-card__link">See a source page</span>
				</a>
				<a class="card track-card" data-tone="olive" href={withBase('/project-euler/problem-0700')}>
					<span class="track-card__index">03</span>
					<span class="eyebrow">Python source</span>
					<h3>A second implementation when it helps</h3>
					<p>The Python version sits next to the write-up when I want a clearer or easier-to-check solution.</p>
					<span class="track-card__link">Open a dual-language entry</span>
				</a>
			</div>
		</section>

		<section class="section-panel">
			<div class="section-heading">
				<div>
					<span class="section-label">Featured Euler problems</span>
					<h2>Good entry points into the largest archive</h2>
					<p>
						A few handpicked problems to show the range: warmup arithmetic, modular arithmetic,
						combinatorics, and one high-number late-archive problem.
					</p>
				</div>
			</div>
			<div class="feature-grid">
				{featuredProblems.map((entry) => (
					<EulerCard
						href={`/project-euler/${entry.id}`}
						title={entry.title}
						description={entry.description}
						updated={entry.updated}
						problem={entry.problem}
						languages={entry.languages}
						answer={entry.answer}
					/>
				))}
			</div>
		</section>

		<section class="section-panel section-panel--signal">
			<div class="section-heading">
				<div>
					<span class="section-label">Latest Euler sync</span>
					<h2>Recently updated Project Euler entries</h2>
					<p>
						Pulled from file timestamps so the homepage can surface recent work without a manual list.
					</p>
				</div>
				<a class="button button--ghost" href={withBase('/about')}>
					About this archive
				</a>
			</div>
			<div class="signal-grid">
				{latestEulerEntries.map((entry, index) => (
					<a class="signal-card" data-tone="olive" href={withBase(`/project-euler/${entry.id}`)}>
						<span class="signal-card__index">0{index + 1}</span>
						<div>
							<span class="eyebrow">{formatProblemNumber(entry.problem)}</span>
							<h3>{entry.title}</h3>
							<p>{entry.description}</p>
						</div>
						<div class="signal-card__meta">
							<span class="metric">{formatDate(entry.updated)}</span>
							<span class="metric">{entry.answer ? `answer ${entry.answer}` : 'full solution'}</span>
						</div>
					</a>
				))}
			</div>
		</section>

		<section class="section-panel">
			<div class="section-heading">
				<div>
					<span class="section-label">Archive depth</span>
					<h2>Project Euler still carries the longest writeups</h2>
					<p>
						The competitive programming section is intentionally more concise. Project Euler is still
						where the most detailed mathematics on the site tends to land.
					</p>
				</div>
			</div>
			<div class="stats-grid">
				<div class="stat">
					<span class="stat__value">{Math.round(totalEulerWords / 1000)}k</span>
					<span class="stat__label">Words in Euler archive</span>
				</div>
				<div class="stat">
					<span class="stat__value">{cpSummaries[0]?.entryCount ?? 0}</span>
					<span class="stat__label">ICPC entries</span>
				</div>
				<div class="stat">
					<span class="stat__value">{cpSummaries[1]?.entryCount ?? 0}</span>
					<span class="stat__label">IOI entries</span>
				</div>
				<div class="stat">
					<span class="stat__value">{cpSummaries.reduce((sum, summary) => sum + summary.yearCount, 0)}</span>
					<span class="stat__label">CP contest years</span>
				</div>
			</div>
		</section>
	</div>
</BaseLayout>
