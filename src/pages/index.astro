---
import EulerCard from '../features/project-euler/components/EulerCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatDate } from '../lib/content';
import { formatProblemNumber, getEulerRecords } from '../features/project-euler/lib/euler';
import { withBase } from '../lib/paths';
import { focusAreas } from '../site.config';

const entries = await getEulerRecords();
const featuredProblems = [1, 48, 250, 700].flatMap((problem) => {
	const entry = entries.find((item) => item.problem === problem);
	return entry ? [entry] : [];
});
const latestEntries = [...entries]
	.sort((a, b) => b.updated.getTime() - a.updated.getTime())
	.slice(0, 4);
const totalWords = entries.reduce((sum, entry) => sum + entry.wordCount, 0);
---

<BaseLayout
	title="Project Euler"
	description="A polished Project Euler archive with full mathematical solutions and source code."
>
	<section class="hero">
		<div class="panel hero-copy">
			<div class="hero-copy__topline">
				<span class="eyebrow">Project Euler archive</span>
				<span class="hero-copy__burst">{entries.length} full problems</span>
			</div>
			<h1>Full Project Euler solutions, cleaner design, both C++ and Python.</h1>
			<p>
				This site is centered on Project Euler: full mathematical writeups, algorithm
				explanations, and source code side by side. It stays static, fast, and easy to scan even
				with hundreds of problems in the archive.
			</p>
			<div class="hero-actions">
				<a class="button" href={withBase('/project-euler')}>Browse all problems</a>
				<a class="button button--ghost" href={withBase('/project-euler/problem-0001')}>
					Open problem 0001
				</a>
			</div>
			<div class="hero-ledger">
				{focusAreas.map((item, index) => (
					<div class="hero-ledger__card">
						<span class="hero-ledger__label">Focus 0{index + 1}</span>
						<strong class="hero-ledger__value">{item}</strong>
					</div>
				))}
			</div>
		</div>

		<aside class="hero-aside">
			<div class="hero-aside__panel hero-aside__panel--warm">
				<span class="eyebrow">What each page includes</span>
				<p class="lede">
					The problem statement, a full derivation, the final answer, and the original C++ and
					Python files from the archive.
				</p>
				<p class="hero-note">
					The detail pages are built for reference: read the reasoning first, then switch
					directly into source code without leaving the page.
				</p>
			</div>
			<div class="hero-aside__panel hero-aside__panel--grid">
				<span class="section-label">Archive scope</span>
				<div class="stats-grid">
					<div class="stat">
						<span class="stat__value">{entries.length}</span>
						<span class="stat__label">Euler problems</span>
					</div>
					<div class="stat">
						<span class="stat__value">{entries.length * 2}</span>
						<span class="stat__label">Source files</span>
					</div>
					<div class="stat">
						<span class="stat__value">2</span>
						<span class="stat__label">Languages per page</span>
					</div>
					<div class="stat">
						<span class="stat__value">{Math.round(totalWords / 1000)}k</span>
						<span class="stat__label">Words in archive</span>
					</div>
				</div>
			</div>
		</aside>
	</section>

	<div class="section-stack">
		<section class="section-panel section-panel--spotlight">
			<div class="section-heading">
				<div>
					<span class="section-label">Archive format</span>
					<h2>Built like a serious Project Euler library</h2>
					<p>
						The front page stays editorial, but the archive and detail pages are optimized for
						actual use: scan, open, verify, copy, move on.
					</p>
				</div>
			</div>
			<div class="track-grid">
				<a class="card track-card" data-tone="warm" href={withBase('/project-euler')}>
					<span class="track-card__index">01</span>
					<span class="eyebrow">Full writeups</span>
					<h3>The mathematics stays visible</h3>
					<p>Problem statements, proofs, algorithm notes, complexity analysis, and answers on one page.</p>
					<span class="track-card__link">Browse the archive</span>
				</a>
				<a class="card track-card" data-tone="cool" href={withBase('/project-euler/problem-0048')}>
					<span class="track-card__index">02</span>
					<span class="eyebrow">C++ source</span>
					<h3>Reference implementation for performance-minded solves</h3>
					<p>Every problem page exposes the exact C++ file from the local Project Euler archive.</p>
					<span class="track-card__link">See a source page</span>
				</a>
				<a class="card track-card" data-tone="olive" href={withBase('/project-euler/problem-0700')}>
					<span class="track-card__index">03</span>
					<span class="eyebrow">Python source</span>
					<h3>A second implementation for clarity and cross-checking</h3>
					<p>The Python version lives next to the writeup so the explanation and the code stay in sync.</p>
					<span class="track-card__link">Open a dual-language entry</span>
				</a>
			</div>
		</section>

		<section class="section-panel">
			<div class="section-heading">
				<div>
					<span class="section-label">Featured problems</span>
					<h2>Good entry points into the archive</h2>
					<p>
						A few handpicked problems to show the range: warmup arithmetic, modular arithmetic,
						combinatorics, and one high-number late-archive problem.
					</p>
				</div>
			</div>
			<div class="feature-grid">
				{featuredProblems.map((entry) => (
					<EulerCard
						href={`/project-euler/${entry.id}`}
						title={entry.title}
						description={entry.description}
						updated={entry.updated}
						problem={entry.problem}
						languages={entry.languages}
						answer={entry.answer}
					/>
				))}
			</div>
		</section>

		<section class="section-panel section-panel--signal">
			<div class="section-heading">
				<div>
					<span class="section-label">Latest sync</span>
					<h2>Recently updated source entries</h2>
					<p>
						These are pulled from the source file timestamps, so the homepage can surface
						recently touched Project Euler entries without manual editing.
					</p>
				</div>
				<a class="button button--ghost" href={withBase('/about')}>About this archive</a>
			</div>
			<div class="signal-grid">
				{latestEntries.map((entry, index) => (
					<a class="signal-card" data-tone="olive" href={withBase(`/project-euler/${entry.id}`)}>
						<span class="signal-card__index">0{index + 1}</span>
						<div>
							<span class="eyebrow">{formatProblemNumber(entry.problem)}</span>
							<h3>{entry.title}</h3>
							<p>{entry.description}</p>
						</div>
						<div class="signal-card__meta">
							<span class="metric">{formatDate(entry.updated)}</span>
							<span class="metric">{entry.answer ? `answer ${entry.answer}` : 'full solution'}</span>
						</div>
					</a>
				))}
			</div>
		</section>
	</div>
</BaseLayout>
