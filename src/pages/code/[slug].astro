---
import { render, getCollection } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
	const entries = await getCollection('code', ({ data }) => !data.draft);

	return entries.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const metaItems = [
	...(entry.data.readingTime ? [{ label: 'Reading time', value: entry.data.readingTime }] : []),
	...(entry.data.repository ? [{ label: 'Repository', value: 'Linked below' }] : []),
];
---

<PostLayout
	title={entry.data.title}
	description={entry.data.description}
	published={entry.data.published}
	updated={entry.data.updated}
	eyebrow="Code note"
	backHref="/code"
	backLabel="All code notes"
	tags={entry.data.tags}
	metaItems={metaItems}
	headings={headings}
	primaryLink={entry.data.repository ? { label: 'Open repository', href: entry.data.repository } : undefined}
>
	<Content />
</PostLayout>
