---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/paths';
---

<BaseLayout title="Not found" description="The page you requested does not exist.">
	<section class="not-found">
		<span class="eyebrow">404</span>
		<h1>That page is not in the archive.</h1>
		<p class="lede">
			Try the home page, the essay index, Project Euler, or the competitive programming archive
			instead.
		</p>
		<div class="chip-row" style="justify-content: center; margin-top: 1.5rem;">
			<a class="button" href={withBase('/')}>Home</a>
			<a class="button button--ghost" href={withBase('/essays')}>Essays</a>
			<a class="button button--ghost" href={withBase('/project-euler')}>Project Euler</a>
			<a class="button button--ghost" href={withBase('/competitive-programming')}>
				Competitive Programming
			</a>
		</div>
	</section>
</BaseLayout>
