---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { formatDate } from '../lib/content';
import { withBase } from '../lib/paths';

interface MetaItem {
	label: string;
	value: string;
}

interface LinkItem {
	label: string;
	href: string;
}

interface HeadingItem {
	depth: number;
	slug: string;
	text: string;
}

interface Props {
	title: string;
	description: string;
	published?: Date;
	publishedLabel?: string;
	updated?: Date;
	eyebrow: string;
	backHref: string;
	backLabel: string;
	tags?: string[];
	metaItems?: MetaItem[];
	headings?: HeadingItem[];
	primaryLink?: LinkItem;
	secondaryLinks?: LinkItem[];
}

const {
	title,
	description,
	published,
	publishedLabel = 'Published',
	updated,
	eyebrow,
	backHref,
	backLabel,
	tags = [],
	metaItems = [],
	headings = [],
	primaryLink,
	secondaryLinks = [],
} = Astro.props;
const visibleMetaItems = [
	...(published ? [{ label: publishedLabel, value: formatDate(published) }] : []),
	...(updated ? [{ label: 'Updated', value: formatDate(updated) }] : []),
	...metaItems.filter((item) => item.value),
];
---

<BaseLayout title={title} description={description}>
	<article class="article-shell">
		<div class="post-content">
			<a class="post-layout__back" href={withBase(backHref)}>
				<span aria-hidden="true">&larr;</span>
				<span>{backLabel}</span>
			</a>

			<header class="post-header">
				<span class="eyebrow">{eyebrow}</span>
				<h1>{title}</h1>
				<p>{description}</p>
				<div class="meta-grid">
					{
						visibleMetaItems.map((item) => (
							<div class="meta-item">
								<strong>{item.label}</strong>
								<span>{item.value}</span>
							</div>
						))
					}
				</div>
				{
					tags.length ? (
						<div class="chip-row">
							{tags.map((tag) => (
								<span class="chip">{tag}</span>
							))}
						</div>
					) : null
				}
			</header>

			<div class="post-content">
				<slot />
			</div>
		</div>

		<aside class="post-sidebar">
			{primaryLink || secondaryLinks.length ? (
				<div class="post-actions">
					{primaryLink ? <a class="button" href={primaryLink.href}>{primaryLink.label}</a> : null}
					{secondaryLinks.map((link) => (
						<a class="button button--ghost" href={link.href}>{link.label}</a>
					))}
				</div>
			) : null}
			<TableOfContents headings={headings} />
		</aside>
	</article>
</BaseLayout>
