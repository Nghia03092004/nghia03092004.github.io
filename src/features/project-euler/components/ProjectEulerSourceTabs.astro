---
interface Props {
	problem: number;
	cppSource: string;
	pythonSource: string;
	cppPath: string;
	pythonPath: string;
}

const { problem, cppSource, pythonSource, cppPath, pythonPath } = Astro.props;
const rootId = `source-tabs-${problem}`;
const cppCodeId = `${rootId}-code-cpp`;
const pythonCodeId = `${rootId}-code-python`;
---

<section class="source-library panel" id="code" data-source-root={rootId}>
	<div class="source-library__header">
		<div>
			<span class="section-label">Source code</span>
			<h2>Code</h2>
			<p>
				Each problem page includes the exact C++ and Python source files from the local archive.
			</p>
		</div>
		<div class="source-toolbar" role="tablist" aria-label="Source language">
			<button class="source-tab is-active" type="button" data-source-tab="cpp" role="tab">
				C++
			</button>
			<button class="source-tab" type="button" data-source-tab="python" role="tab">
				Python
			</button>
		</div>
	</div>

	<article class="source-panel is-active" id="cpp-source" data-source-panel="cpp">
		<div class="source-panel__meta">
			<span class="metric">C++</span>
			<code>{cppPath}</code>
			<button class="source-copy" type="button" data-copy-target={cppCodeId}>Copy</button>
		</div>
		<pre><code id={cppCodeId} class="language-cpp">{cppSource}</code></pre>
	</article>

	<article class="source-panel" id="python-source" data-source-panel="python" hidden>
		<div class="source-panel__meta">
			<span class="metric">Python</span>
			<code>{pythonPath}</code>
			<button class="source-copy" type="button" data-copy-target={pythonCodeId}>Copy</button>
		</div>
		<pre><code id={pythonCodeId} class="language-python">{pythonSource}</code></pre>
	</article>
</section>

<script is:inline>
	const sourceRoots = document.querySelectorAll('[data-source-root]');

	sourceRoots.forEach((root) => {
		const buttons = Array.from(root.querySelectorAll('[data-source-tab]'));
		const panels = Array.from(root.querySelectorAll('[data-source-panel]'));

		const setActive = (language) => {
			buttons.forEach((button) => {
				const isActive = button.dataset.sourceTab === language;
				button.classList.toggle('is-active', isActive);
				button.setAttribute('aria-selected', String(isActive));
			});

			panels.forEach((panel) => {
				const isActive = panel.dataset.sourcePanel === language;
				panel.classList.toggle('is-active', isActive);
				panel.hidden = !isActive;
			});
		};

		buttons.forEach((button) => {
			button.addEventListener('click', () => setActive(button.dataset.sourceTab));
		});

		setActive('cpp');
	});
</script>
