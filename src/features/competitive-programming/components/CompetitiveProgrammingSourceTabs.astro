---
import { withBase } from '../../../lib/paths';

interface SourceTab {
	id: string;
	label: string;
	description: string;
	path: string;
	rawUrl: string;
	languageClass: string;
	source: string;
}

interface Props {
	rootId: string;
	sectionId?: string;
	sectionLabel?: string;
	title?: string;
	description?: string;
	showPaths?: boolean;
	tabs: SourceTab[];
}

const {
	rootId,
	sectionId = 'source-files',
	sectionLabel = 'Source files',
	title = 'Source files',
	description = 'The implementation is shown directly from the repository source.',
	showPaths = true,
	tabs,
} = Astro.props;
const firstTab = tabs[0];
const showTabs = tabs.length > 1;
---

<section
	class="source-library panel"
	id={sectionId}
	data-source-root={rootId}
	data-default-tab={firstTab?.id ?? 'tex'}
>
	<div class="source-library__header">
		<div>
			<span class="section-label">{sectionLabel}</span>
			<h2>{title}</h2>
			<p>{description}</p>
		</div>
		{
			showTabs ? (
				<div class="source-toolbar" role="tablist" aria-label="Source file type">
					{
						tabs.map((tab, index) => (
							<button
								class:list={['source-tab', index === 0 && 'is-active']}
								type="button"
								data-source-tab={tab.id}
								role="tab"
								aria-selected={index === 0 ? 'true' : 'false'}
							>
								{tab.label}
							</button>
						))
					}
				</div>
			) : null
		}
	</div>

	{
		tabs.map((tab, index) => (
			<article
				class:list={['source-panel', index === 0 && 'is-active']}
				data-source-panel={tab.id}
				hidden={index === 0 ? undefined : true}
			>
				<div class="source-panel__meta">
					<div class="source-panel__copy">
						<span class="metric">{tab.label}</span>
						{showPaths ? <code>{tab.path}</code> : null}
						<p>{tab.description}</p>
					</div>
					<div class="source-panel__actions">
						<a class="button button--ghost" href={withBase(tab.rawUrl)}>Raw file</a>
						<button
							class="source-copy"
							type="button"
							data-copy-target={`${rootId}-${tab.id}-code`}
						>
							Copy
						</button>
					</div>
				</div>
				<pre><code id={`${rootId}-${tab.id}-code`} class={tab.languageClass}>{tab.source}</code></pre>
			</article>
		))
	}
</section>

<script is:inline>
	const sourceRoots = document.querySelectorAll('[data-source-root]');

	sourceRoots.forEach((root) => {
		if (root.dataset.sourceInitialized === 'true') {
			return;
		}

		const buttons = Array.from(root.querySelectorAll('[data-source-tab]'));
		const panels = Array.from(root.querySelectorAll('[data-source-panel]'));

		const setActive = (tabId) => {
			buttons.forEach((button) => {
				const isActive = button.dataset.sourceTab === tabId;
				button.classList.toggle('is-active', isActive);
				button.setAttribute('aria-selected', String(isActive));
			});

			panels.forEach((panel) => {
				const isActive = panel.dataset.sourcePanel === tabId;
				panel.classList.toggle('is-active', isActive);
				panel.hidden = !isActive;
			});
		};

		buttons.forEach((button) => {
			button.addEventListener('click', () => setActive(button.dataset.sourceTab));
		});

		setActive(root.dataset.defaultTab ?? 'tex');
		root.dataset.sourceInitialized = 'true';
	});
</script>
